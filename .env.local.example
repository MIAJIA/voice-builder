# Anthropic API Key
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# OpenAI API Key (for DALL-E image generation)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# ===== Social Listening Agent =====
# Notion integration for storing leads
# Create integration at: https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_api_key_here
NOTION_LEADS_DATABASE_ID=your_database_id_here

# Apify for social media scraping
# Get your token from: https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here

# Slack notifications (optional)
# Create incoming webhook at: https://api.slack.com/apps
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# ===== Analytics =====
# PostHog for user behavior tracking
# Get your key from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ===== Feedback =====
# Notion database for user feedback
NOTION_FEEDBACK_DATABASE_ID=your_feedback_database_id_here
